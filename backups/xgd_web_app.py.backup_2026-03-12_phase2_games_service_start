        if mode_norm == "historical":
            with self.lock:
                games_df = self.historical_games_df.copy()
                last_refresh = self.last_refresh
            fill_missing_days = False
        else:
            mode_norm = "upcoming"
            self.refresh_games(force=False)
            with self.lock:
                games_df = self.games_df.copy()
                last_refresh = self.last_refresh
            fill_missing_days = True

        if games_df.empty:
            return {
                "days": [],
                "tiers": [],
